			<key>CFBundleTypeName</key>
			<string>Adobe InDesign Book</string>
			<key>CFBundleTypeIconFile</key>
			<string>ID_Book_Icon</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.adobe.indesign-book</string>
			</array>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>indb</string>
			</array>
		</dict>
		<!-- InDesign Library (.indl) -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Adobe InDesign Library</string>
			<key>CFBundleTypeIconFile</key>
			<string>ID_Library_CC_Icon</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.adobe.indesign-library</string>
			</array>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>indl</string>
			</array>
		</dict>
		<!-- InDesign Markup Language (.idml) -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>Adobe InDesign Markup Language</string>
			<key>CFBundleTypeIconFile</key>
			<string>ID_IDMLFile_Icon</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.adobe.indesign.idml</string>
			</array>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>idml</string>
			</array>
		</dict>
		<!-- すべてのファイル（フォルダ以外） -->
		<dict>
			<key>CFBundleTypeName</key>
			<string>All Files</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.item</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
